# Copie este arquivo para ".env" e preencha com suas credenciais quando as tiver.
# Sem essas variaveis, o sistema funciona em modo "somente leitura" (busca publica,
# tendencias e geracao de relatorios de preco), mas nao consegue atualizar precos
# dos seus anuncios automaticamente.

# Criados em https://developers.mercadolibre.com.br/ (criar uma aplicacao)
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://localhost

# Obtidos apos o fluxo OAuth (veja src/ml_client.py -> get_authorization_url / exchange_code_for_token)
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# Seu ID de vendedor no Mercado Livre (necessario para listar/atualizar seus anuncios)
ML_SELLER_ID=

# Site (pais). MLB = Brasil, MLA = Argentina, MLM = Mexico, etc.
ML_SITE_ID=MLB
